@model TmsSystem.Models.Trip

@{
    ViewData["Title"] = "טיול חדש";
}

<style>
    /* RTL רק לשדות טקסט */
    .form-control, .form-select, textarea {
        direction: rtl;
        text-align: right;
    }

    .form-label, label {
        direction: rtl;
        text-align: right;
    }

    h1, h2, h3, h4, h5, h6 {
        direction: rtl;
        text-align: right;
    }
</style>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3><i class="fas fa-plus-circle"></i> יצירת טיול חדש</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data" id="tripForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- פרטים בסיסיים -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label">שם הטיול *</label>
                        <input asp-for="Title" class="form-control" placeholder="לדוגמה: טיול מאורגן בצפון" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="NumberOfDays" class="form-label">מספר ימים *</label>
                        <select asp-for="NumberOfDays" class="form-select" id="numberOfDays">
                            @for (int i = 4; i <= 31; i++)
                            {
                                <option value="@i">@i ימים</option>
                            }
                        </select>
                        <span asp-validation-for="NumberOfDays" class="text-danger"></span>
                    </div>
                </div>

                <!-- 👨‍✈️ שדה מדריך + סוג טיול -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="GuideId" class="form-label">
                            <i class="fas fa-user-tie"></i> מדריך מלווה (אופציונלי)
                        </label>
                        <select asp-for="GuideId" class="form-select" asp-items="ViewBag.Guides">
                            <option value="">-- ללא מדריך / נבחר בהמשך --</option>
                        </select>
                        <span asp-validation-for="GuideId" class="text-danger"></span>
                        <small class="form-text text-muted">
                            ניתן לשייך מדריך לטיול או לבחור בהמשך
                        </small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="TripType" class="form-label">
                            <i class="fas fa-tags"></i> סוג טיול
                        </label>
                        <select asp-for="TripType" class="form-select" asp-items="ViewBag.TourTypes">
                            <option value="">-- בחר סוג --</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">תיאור הטיול</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="תיאור כללי של הטיול... "></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <hr />

                <!-- ימי הטיול -->
                <h4 class="mb-3"><i class="fas fa-calendar-day"></i> פירוט ימי הטיול</h4>
                <div id="tripDaysContainer">
                    <!-- הימים יווצרו דינמית ב-JavaScript -->
                </div>

                <hr />

                <!-- פרטי מחיר ופרטים נוספים -->
                <div class="card mb-3 bg-light">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-dollar-sign"></i> פרטי מחיר ומידע נוסף</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PricePerPerson" class="form-label">מחיר לאדם</label>
                                <div class="input-group">
                                    <input asp-for="PricePerPerson" class="form-control" type="number" step="0.01" placeholder="1500" />
                                    <span class="input-group-text">$</span>
                                </div>
                                <span asp-validation-for="PricePerPerson" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PriceDescription" class="form-label">תיאור מחיר</label>
                                <input asp-for="PriceDescription" class="form-control" placeholder="לדוגמה: 1500$ לאדם בחדר זוגי" />
                                <span asp-validation-for="PriceDescription" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Includes" class="form-label">המחיר כולל</label>
                                <textarea asp-for="Includes" class="form-control" rows="6" placeholder="לדוגמה:&#10;לינה במלונות 4-5 כוכבים&#10;ארוחות בוקר&#10;הסעות באוטובוס מפואר&#10;מדריך מקצועי צמוד&#10;כניסה לכל האתרים"></textarea>
                                <small class="form-text text-muted">כל פריט בשורה נפרדת</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Excludes" class="form-label">המחיר אינו כולל</label>
                                <textarea asp-for="Excludes" class="form-control" rows="6" placeholder="לדוגמה:&#10;טיסות בינלאומיות&#10;ביטוח נסיעות&#10;ארוחות צהריים וערב&#10;הוצאות אישיות&#10;טיפים"></textarea>
                                <small class="form-text text-muted">כל פריט בשורה נפרדת</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FlightDetails" class="form-label">פרטי טיסות</label>
                            <textarea asp-for="FlightDetails" class="form-control" rows="5" placeholder="לדוגמה:&#10;טיסות זמינות:&#10;אל על LY315 - יציאה: 06:00, נחיתה: 10:30&#10;ישראייר 6H501 - יציאה: 14:00, נחיתה: 18:30&#10;&#10;מחיר טיסה הלוך-חזור: כ-800$"></textarea>
                            <small class="form-text text-muted">פרטי טיסות זמינות ומחירים משוערים</small>
                        </div>

                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">טיול פעיל</label>
                        </div>
                    </div>
                </div>

                <!-- מחירון -->
                <div class="card mb-3 bg-light">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-list-ol"></i> מחירון</h5>
                    </div>
                    <div class="card-body">
                        <div id="price-items">
                            <div class="row mb-2 price-item-row">
                                <div class="col-md-5">
                                    <label class="form-label">קטגוריה</label>
                                    <input type="text" name="PriceItems[0].CategoryName" class="form-control" placeholder="למשל: זוג, ילד, 4 אנשים" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">מחיר ($)</label>
                                    <input type="number" name="PriceItems[0].Price" class="form-control" step="0.01" min="0" placeholder="0.00" />
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <button type="button" class="btn btn-danger btn-sm" onclick="removePriceItem(this)">הסר</button>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn btn-secondary mt-2" onclick="addPriceItem()">הוסף שורת מחיר</button>
                    </div>
                </div>

                <!-- כפתורי שמירה -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                        <i class="fas fa-arrow-right"></i> חזרה
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> שמור טיול
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Image Gallery Modal -->
<div class="modal fade" id="imageGalleryModal" tabindex="-1" aria-labelledby="imageGalleryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageGalleryModalLabel"><i class="fas fa-images"></i> בחר תמונה מהספרייה</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-3">
                    <p class="text-muted">טוען תמונות...</p>
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">טוען...</span>
                    </div>
                </div>
                <div id="galleryImagesContainer" class="row g-3" style="display: none;">
                    <!-- Gallery images will be loaded here dynamically -->
                </div>
                <div id="galleryEmptyMessage" class="alert alert-info text-center" style="display: none;">
                    <i class="fas fa-info-circle"></i> אין תמונות בספרייה.
                    <a href="@Url.Action("Index", "ImageGallery")" target="_blank" class="alert-link">לחץ כאן להעלאת תמונות</a>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">סגור</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ===== רשימת מלונות מהשרת =====
        var hotelsList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((ViewBag.Hotels as List<string>) ?? new List<string>()));

        $(document).ready(function () {
            var TripImageGallery = { currentDayIndex: -1 };

            // ===== AUTO-SAVE DRAFT (localStorage) =====
            var DRAFT_KEY = 'trip_create_draft';
            var autoSaveTimer;

            function saveDraft() {
                var data = {};
                $('#tripForm').find('input:not([type=file]), select, textarea').each(function() {
                    if (this.name) data[this.name] = $(this).val();
                });
                // שמור גם מספר הימים
                data['__numberOfDays'] = $('#numberOfDays').val();
                localStorage.setItem(DRAFT_KEY, JSON.stringify(data));
            }

            function loadDraft() {
                var raw = localStorage.getItem(DRAFT_KEY);
                if (!raw) return;
                try {
                    var data = JSON.parse(raw);
                    if (data['__numberOfDays']) {
                        var days = parseInt(data['__numberOfDays']);
                        $('#numberOfDays').val(days);
                        generateDays(days, data);
                    }
                    // שחזר שדות כלליים
                    $.each(data, function(name, val) {
                        if (name.startsWith('__') || name.startsWith('TripDays[')) return;
                        var el = $('[name="' + name + '"]');
                        if (el.length) el.val(val);
                    });
                    showDraftBanner();
                } catch(e) {}
            }

            function showDraftBanner() {
                if ($('#draftBanner').length) return;
                var banner = $('<div id="draftBanner" class="alert alert-info alert-dismissible mt-2">' +
                    '<i class="fas fa-save me-2"></i> <strong>טיוטה שמורה שוחזרה.</strong> ' +
                    '<button type="button" class="btn btn-sm btn-danger ms-3" id="clearDraftBtn">מחק טיוטה</button>' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '</div>');
                $('#tripForm').prepend(banner);
                $('#clearDraftBtn').on('click', function() {
                    localStorage.removeItem(DRAFT_KEY);
                    $('#draftBanner').remove();
                });
            }

            // שמור אוטומטית בכל שינוי
            $(document).on('change input', '#tripForm input:not([type=file]), #tripForm select, #tripForm textarea', function() {
                clearTimeout(autoSaveTimer);
                autoSaveTimer = setTimeout(saveDraft, 800);
            });

            // מחיקת טיוטה בעת שמירה
            $('#tripForm').on('submit', function() {
                localStorage.removeItem(DRAFT_KEY);
            });

            // ===== GALLERY =====
            function loadGalleryImages() {
                $.ajax({
                    url: '@Url.Action("GetImages", "ImageGallery")',
                    type: 'GET',
                    success: function(images) {
                        var container = $('#galleryImagesContainer');
                        container.empty();
                        if (images && images.length > 0) {
                            images.forEach(function(image) {
                                container.append(`
                                    <div class="col-md-3 col-sm-6">
                                        <div class="card h-100 gallery-image-card" style="cursor: pointer;" data-image-path="${image.filePath}">
                                            <img src="${image.filePath}" class="card-img-top" alt="${image.fileName}" style="height: 200px; object-fit: cover;">
                                            <div class="card-body p-2"><small class="text-muted">${image.description || image.fileName}</small></div>
                                        </div>
                                    </div>`);
                            });
                            container.show();
                            $('#galleryEmptyMessage').hide();
                            $('.spinner-border').parent().hide();
                            $('.gallery-image-card').on('click', function() {
                                selectImageFromGallery($(this).data('image-path'));
                            });
                        } else {
                            container.hide();
                            $('#galleryEmptyMessage').show();
                            $('.spinner-border').parent().hide();
                        }
                    },
                    error: function() {
                        $('#galleryImagesContainer').hide();
                        $('.spinner-border').parent().html('<div class="alert alert-danger">שגיאה בטעינת תמונות.</div>');
                    }
                });
            }

            function selectImageFromGallery(imagePath) {
                if (TripImageGallery.currentDayIndex < 0) return;
                var card = $('.trip-day-card').eq(TripImageGallery.currentDayIndex);
                card.find('.image-path-input').val(imagePath);
                var preview = card.find('.gallery-preview');
                preview.find('img').attr('src', imagePath);
                preview.show();
                card.find('.day-image-input').val('');
                $('#imageGalleryModal').modal('hide');
            }

            $(document).on('click', '.select-from-gallery-btn', function(e) {
                e.preventDefault();
                TripImageGallery.currentDayIndex = $(this).closest('.trip-day-card').index();
                loadGalleryImages();
                $('#imageGalleryModal').modal('show');
            });

            $(document).on('change', '.day-image-input', function() {
                var input = this;
                var card = $(input).closest('.trip-day-card');
                if (input.files && input.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        card.find('.gallery-preview img').attr('src', e.target.result);
                        card.find('.gallery-preview').show();
                        card.find('.image-path-input').val('');
                    };
                    reader.readAsDataURL(input.files[0]);
                }
            });

            // ===== ניהול ימים =====

            function buildHotelOptions(selectedVal) {
                var opts = '<option value="">-- ללא מלון --</option>';
                if (hotelsList && hotelsList.length > 0) {
                    hotelsList.forEach(function(h) {
                        var sel = (h === selectedVal) ? ' selected' : '';
                        opts += '<option value="' + h + '"' + sel + '>' + h + '</option>';
                    });
                }
                return opts;
            }

            function buildDayCard(index, title, location, description, hotelName) {
                var dayNumber = index + 1;
                title = title || ('יום ' + dayNumber);
                location = location || '';
                description = description || '';
                hotelName = hotelName || '';
                return `
                    <div class="card mb-3 trip-day-card">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">יום <span class="day-number">${dayNumber}</span></h5>
                            <button type="button" class="btn btn-sm btn-outline-success insert-day-btn" title="הוסף יום אחרי יום זה">
                                <i class="fas fa-plus"></i> הוסף יום כאן
                            </button>
                        </div>
                        <div class="card-body">
                            <input type="hidden" class="day-number-input" name="TripDays[${index}].DayNumber" value="${dayNumber}" />
                            <input type="hidden" name="TripDays[${index}].DisplayOrder" value="${dayNumber}" />

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">כותרת *</label>
                                    <input name="TripDays[${index}].Title" class="form-control day-title" placeholder="לדוגמה: יום פתיחה - הגעה למלון" value="${title}" required />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">מיקום</label>
                                    <input name="TripDays[${index}].Location" class="form-control" placeholder="לדוגמה: צפת העתיקה" value="${location}" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label"><i class="fas fa-hotel"></i> שם בית המלון</label>
                                    <select name="TripDays[${index}].HotelName" class="form-select hotel-select">
                                        ${buildHotelOptions(hotelName)}
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">תיאור</label>
                                <textarea name="TripDays[${index}].Description" class="form-control" rows="4" placeholder="פירוט מלא של פעילויות היום...">${description}</textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">תמונה ליום</label>
                                <div class="btn-group d-flex mb-2" role="group">
                                    <button type="button" class="btn btn-outline-primary select-from-gallery-btn">
                                        <i class="fas fa-images"></i> בחר מהספרייה
                                    </button>
                                    <label class="btn btn-outline-secondary" style="cursor: pointer;">
                                        <i class="fas fa-upload"></i> העלה חדשה
                                        <input type="file" name="dayImages_${index}" class="form-control day-image-input d-none" accept="image/*" />
                                    </label>
                                </div>
                                <input type="hidden" name="TripDays[${index}].ImagePath" value="" class="image-path-input" />
                                <div class="gallery-preview" style="display: none; margin-top: 10px;">
                                    <img src="" alt="תמונה נבחרה" class="img-thumbnail" style="max-height: 150px; max-width: 100%;">
                                </div>
                                <small class="form-text text-muted">גודל מומלץ: 1200x800 פיקסלים</small>
                            </div>
                        </div>
                    </div>
                `;
            }

            window.generateDays = function(numDays, draftData) {
                var container = $('#tripDaysContainer');
                container.empty();
                for (var i = 0; i < numDays; i++) {
                    var title = draftData ? (draftData['TripDays[' + i + '].Title'] || '') : '';
                    var location = draftData ? (draftData['TripDays[' + i + '].Location'] || '') : '';
                    var description = draftData ? (draftData['TripDays[' + i + '].Description'] || '') : '';
                    var hotel = draftData ? (draftData['TripDays[' + i + '].HotelName'] || '') : '';
                    container.append(buildDayCard(i, title, location, description, hotel));
                }
                reindexDays();
            };

            var initialDays = parseInt($('#numberOfDays').val()) || 7;

            // בדוק טיוטה בטעינה
            var hasDraft = !!localStorage.getItem(DRAFT_KEY);
            if (hasDraft) {
                loadDraft();
            } else {
                generateDays(initialDays);
            }

            $('#numberOfDays').change(function () {
                generateDays(parseInt($(this).val()));
            });

            // ===== הוסף יום באמצע =====
            $(document).on('click', '.insert-day-btn', function() {
                var card = $(this).closest('.trip-day-card');
                var newCard = $(buildDayCard(0, '', '', '', ''));
                newCard.insertAfter(card);
                reindexDays();
                // עדכן מספר ימים בסלקט
                var totalDays = $('.trip-day-card').length;
                $('#numberOfDays').val(totalDays);
                saveDraft();
            });

            function reindexDays() {
                $('.trip-day-card').each(function(i) {
                    var card = $(this);
                    var dayNum = i + 1;
                    card.find('.day-number').text(dayNum);
                    card.find('.day-number-input').attr('name', 'TripDays[' + i + '].DayNumber').val(dayNum);
                    card.find('input[name*="DisplayOrder"]').attr('name', 'TripDays[' + i + '].DisplayOrder').val(dayNum);
                    card.find('.day-title').attr('name', 'TripDays[' + i + '].Title');
                    card.find('input[name*=".Location"]').attr('name', 'TripDays[' + i + '].Location');
                    card.find('.hotel-select').attr('name', 'TripDays[' + i + '].HotelName');
                    card.find('textarea').attr('name', 'TripDays[' + i + '].Description');
                    card.find('.image-path-input').attr('name', 'TripDays[' + i + '].ImagePath');
                    card.find('.day-image-input').attr('name', 'dayImages_' + i);
                    card.find('.select-from-gallery-btn').attr('data-day-index', i);
                });
            }
        });

        // ===== מחירון =====
        var priceIndex = 1;
        window.addPriceItem = function() {
            var container = document.getElementById("price-items");
            container.insertAdjacentHTML('beforeend', `
                <div class="row mb-2 price-item-row">
                    <div class="col-md-5">
                        <label class="form-label">קטגוריה</label>
                        <input type="text" name="PriceItems[${priceIndex}].CategoryName" class="form-control" placeholder="למשל: זוג, ילד, 4 אנשים" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">מחיר</label>
                        <input type="number" name="PriceItems[${priceIndex}].Price" class="form-control" step="0.01" min="0" placeholder="0.00" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-danger btn-sm" onclick="removePriceItem(this)">הסר</button>
                    </div>
                </div>
            `);
            priceIndex++;
        };

        window.removePriceItem = function(button) {
            button.closest('.price-item-row').remove();
            var rows = document.querySelectorAll('#price-items .price-item-row');
            rows.forEach(function(row, idx) {
                row.querySelector('input[name*="CategoryName"]').name = `PriceItems[${idx}].CategoryName`;
                row.querySelector('input[name*="Price"]').name = `PriceItems[${idx}].Price`;
            });
            priceIndex = rows.length;
        };
    </script>
}