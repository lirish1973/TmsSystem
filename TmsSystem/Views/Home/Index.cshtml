@{
    ViewData["Title"] = "דף הבית";
}

@if (User.Identity.IsAuthenticated)
{
    <!-- Hero Section -->
    <div class="home-hero">
        <h1>ברוכים הבאים לניהול הצעות מחיר</h1>
        <p>נהל את כל הסיורים, הטיולים וההצעות מחיר שלך במקום אחד</p>
        <a asp-controller="Dashboard" asp-action="Index" class="btn-hero" style="color:white;">
            <i class="bi bi-speedometer2"></i> מעבר ל-Dashboard
        </a>
    </div>

    <!-- כרטיסי תפריט ראשי -->
    <div class="menu-cards">
        <!-- Dashboard -->
        <a asp-controller="Dashboard" asp-action="Index" class="menu-card dashboard">
            <div class="icon">
                <i class="bi bi-speedometer2"></i>
            </div>
            <h3>Dashboard</h3>
            <p>צפה בסטטיסטיקות, דוחות ומידע מרוכז על פעילות המערכת</p>
        </a>

        <!-- סיורים -->
        <a asp-controller="Tours" asp-action="Index" class="menu-card tours">
            <div class="icon">
                <i class="bi bi-geo-alt"></i>
            </div>
            <h3>סיורים</h3>
            <p>נהל סיורים של יום אחד - צור, ערוך והצג את כל הסיורים הפעילים</p>
        </a>

        <!-- הצעות מחיר -->
        <a asp-controller="Offers" asp-action="Index" class="menu-card offers">
            <div class="icon">
                <i class="bi bi-cash-stack"></i>
            </div>
            <h3>הצעות מחיר - סיורים</h3>
            <p>צור ונהל הצעות מחיר לסיורים וטיולים, שלח ללקוחות</p>
        </a>

        <!-- טיולים -->
        <a asp-controller="Trips" asp-action="Index" class="menu-card trips">
            <div class="icon">
                <i class="bi bi-map-fill"></i>
            </div>
            <h3>טיולים</h3>
            <p>נהל טיולים של מספר ימים - תכנן מסלולים ומלונות</p>
        </a>

        <!-- הצעות מחיר -->
        <a asp-controller="TripOffers" asp-action="Index" class="menu-card offers">
            <div class="icon">
                <i class="bi bi-cash-stack"></i>
            </div>
            <h3>הצעות מחיר - טיולים</h3>
            <p>צור ונהל הצעות מחיר לסיורים וטיולים, שלח ללקוחות</p>
        </a>

        <!-- לקוחות -->
        <a asp-controller="Customers" asp-action="Index" class="menu-card customers">
            <div class="icon">
                <i class="bi bi-people"></i>
            </div>
            <h3>לקוחות</h3>
            <p>נהל את מאגר הלקוחות - הוסף, ערוך וצפה בפרטי קשר</p>
        </a>

        <!-- מדריכים -->
        <a asp-controller="Guides" asp-action="Index" class="menu-card guides">
            <div class="icon">
                <i class="fas fa-user-tie"></i>
            </div>
            <h3>מדריכים</h3>
            <p>נהל את צוות המדריכים - זמינות, התמחויות ופרטי התקשרות</p>
        </a>
     
        <!-- ניהול משתמשים -->
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Users" asp-action="Index" class="menu-card users" style="background-color:lightslategrey;color:white;">
                <div class="icon">
                    <i class="bi bi-person-gear"></i>
                </div>
                <h3 style="color:white;">ניהול משתמשים</h3>
                <p style="color:white;">פאנל ניהול משתמשים</p>
            </a>
        }
    </div>

    <!-- אזור מידע נוסף -->
    <div class="row mt-5">
        <div class="col-md-4 mb-3">
            <div class="card border-primary h-100">
                <div class="card-body text-center">
                    <i class="bi bi-lightbulb text-primary" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3">טיפים מהירים</h5>
                    <p class="card-text">השתמש בלחצן החיפוש המהיר כדי למצוא סיורים או לקוחות בקלות</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success h-100">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3">עדכונים אחרונים</h5>
                    <p class="card-text">כל הנתונים מסונכרנים בזמן אמת - עבוד בביטחון</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-info h-100">
                <div class="card-body text-center">
                    <i class="bi bi-question-circle text-info" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3">זקוק לעזרה? </h5>
                    <p class="card-text">פנה למנהל המערכת או עיין במדריך המשתמש</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Landing Page - Full Screen -->
    <style>
        body { margin-bottom: 0 !important; overflow-x: hidden; }

        .landing-wrapper {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            margin: -20px -15px 0;
            padding: 60px 20px 40px;
        }

        /* Animated blobs */
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.25;
            animation: blobMove 12s ease-in-out infinite alternate;
        }
        .blob-1 { width: 500px; height: 500px; background: #764ba2; top: -100px; left: -100px; animation-delay: 0s; }
        .blob-2 { width: 400px; height: 400px; background: #667eea; bottom: -80px; right: -80px; animation-delay: 3s; }
        .blob-3 { width: 300px; height: 300px; background: #f093fb; top: 50%; left: 50%; transform: translate(-50%,-50%); animation-delay: 6s; }

        @@keyframes blobMove {
            0%   { transform: translate(0,0) scale(1); }
            50%  { transform: translate(30px,-30px) scale(1.1); }
            100% { transform: translate(-20px,20px) scale(0.95); }
        }
        .blob-3 { animation: blobMove3 14s ease-in-out infinite alternate; }
        @@keyframes blobMove3 {
            0%   { transform: translate(-50%,-50%) scale(1); }
            100% { transform: translate(-45%,-55%) scale(1.15); }
        }

        /* Floating particles */
        .particle {
            position: absolute;
            width: 6px; height: 6px;
            border-radius: 50%;
            background: rgba(255,255,255,0.4);
            animation: floatUp linear infinite;
        }
        @@keyframes floatUp {
            0%   { opacity: 0; transform: translateY(0) scale(0.5); }
            10%  { opacity: 1; }
            90%  { opacity: 0.8; }
            100% { opacity: 0; transform: translateY(-80vh) scale(1.2); }
        }

        /* Glass card */
        .landing-card {
            position: relative;
            z-index: 10;
            background: rgba(255,255,255,0.07);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 28px;
            padding: 50px 60px;
            max-width: 560px;
            width: 100%;
            text-align: center;
            box-shadow: 0 25px 60px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
            animation: cardEntrance 0.8s cubic-bezier(0.22,1,0.36,1) both;
        }
        @@keyframes cardEntrance {
            from { opacity: 0; transform: translateY(40px) scale(0.95); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }

        .landing-logo {
            width: 120px;
            filter: drop-shadow(0 0 20px rgba(255,255,255,0.3));
            animation: logoPulse 3s ease-in-out infinite;
            margin-bottom: 24px;
        }
        @@keyframes logoPulse {
            0%, 100% { filter: drop-shadow(0 0 15px rgba(255,255,255,0.2)); }
            50%       { filter: drop-shadow(0 0 30px rgba(167,139,250,0.6)); }
        }

        .landing-title {
            font-size: 2rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 10px;
            text-shadow: 0 2px 20px rgba(0,0,0,0.3);
            direction: rtl;
            text-align: center;
        }
        .landing-title span {
            background: linear-gradient(135deg, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .landing-sub {
            color: rgba(255,255,255,0.65);
            font-size: 1rem;
            margin-bottom: 36px;
            direction: rtl;
        }

        .btn-landing {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            background: linear-gradient(135deg, #a78bfa 0%, #60a5fa 100%);
            color: white !important;
            font-size: 1.15rem;
            font-weight: 700;
            padding: 14px 40px;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 8px 30px rgba(167,139,250,0.4);
            position: relative;
            overflow: hidden;
        }
        .btn-landing::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .btn-landing:hover::before { opacity: 1; }
        .btn-landing:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 40px rgba(167,139,250,0.55);
        }
        .btn-landing i, .btn-landing span { position: relative; z-index: 1; }

        /* Feature pills */
        .feature-pills {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
            margin-top: 32px;
        }
        .pill {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.8);
            padding: 6px 16px;
            border-radius: 50px;
            font-size: 0.82rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Version badge */
        .version-badge {
            position: relative;
            z-index: 10;
            margin-top: 28px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            color: rgba(255,255,255,0.35);
            font-size: 0.72rem;
            padding: 4px 14px;
            border-radius: 20px;
            letter-spacing: 1px;
            font-family: monospace;
        }
    </style>

    <div class="landing-wrapper">
        <!-- Animated blobs -->
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>

        <!-- Floating particles (JS generated) -->
        <div id="particles-container"></div>

        <!-- Main card -->
        <div class="landing-card">
            <img src="https://www.tryit.co.il/wp-content/uploads/2025/08/cropped-try-it-logo.png"
                 class="landing-logo" alt="TryIt Logo" />

            <div class="landing-title">
                מערכת ניהול <span>TRYIT</span>
            </div>
            <div class="landing-sub">
                סיורים · טיולים · הצעות מחיר · לקוחות
            </div>

            <a asp-controller="Account" asp-action="Login" class="btn-landing">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>התחבר למערכת</span>
            </a>

            <div class="feature-pills">
                <div class="pill"><i class="bi bi-speedometer2"></i> מהיר ונוח</div>
                <div class="pill"><i class="bi bi-shield-check"></i> מאובטח</div>
                <div class="pill"><i class="bi bi-phone"></i> רספונסיבי</div>
                <div class="pill"><i class="bi bi-cloud-check"></i> ענן</div>
            </div>
        </div>

        <!-- Version -->
        <div class="version-badge">v @TmsSystem.AppVersion.Version</div>
    </div>

    <script>
        // Generate floating particles
        const container = document.getElementById('particles-container');
        for (let i = 0; i < 25; i++) {
            const p = document.createElement('div');
            p.className = 'particle';
            p.style.left = Math.random() * 100 + 'vw';
            p.style.bottom = '-10px';
            p.style.width = p.style.height = (Math.random() * 5 + 3) + 'px';
            p.style.animationDuration = (Math.random() * 12 + 8) + 's';
            p.style.animationDelay = (Math.random() * 10) + 's';
            p.style.opacity = Math.random() * 0.5 + 0.2;
            container.appendChild(p);
        }
    </script>
}